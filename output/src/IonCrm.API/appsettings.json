{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Secret": "",
    "AccessTokenExpiryMinutes": 525600,
    "RefreshTokenExpiryDays": 7,
    "Issuer": "IonCrm",
    "Audience": "IonCrmUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://ion-crm-frontend-production.up.railway.app",
      "https://ion-crm-frontend-development.up.railway.app"
    ]
  },
  "SyncSettings": {
    "IntervalMinutes": 15,
    "SaasABaseUrl": "",
    "SaasBBaseUrl": "",
    "SaasAApiKey": "",
    "SaasBApiKey": ""
  },
  "SaasA": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },
  "SaasB": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },
  "Hangfire": {
    "Enabled": false
  },
  "EmailCollector": {
    "Imap": {
      "Host": "",
      "Port": 993,
      "Username": "",
      "Password": "",
      "UseSsl": true
    },
    "Mailbox": "INBOX",
    "LookbackDays": 45,
    "MaxMessages": 300,
    "Rules": [
      {
        "Provider": "Anthropic",
        "FromContains": "anthropic.com",
        "SubjectContains": "receipt from Anthropic",
        "AmountRegex": "Amount paid\\s*\\$([0-9][0-9.,]*)",
        "Currency": "USD",
        "InvoiceNoRegex": "Invoice number\\s*([A-Z0-9-]+)",
        "PeriodMonthOffset": 0
      },
      {
        "Provider": "GoogleWorkspaceRezerval",
        "FromContains": "payments-noreply@google.com",
        "SubjectContains": "rezerval.com",
        "AmountRegex": "Total in [A-Z]{3}[^0-9]{0,20}([0-9][0-9.,]+)",
        "Currency": "TRY",
        "InvoiceNoRegex": "Invoice number\\s*([0-9]+)",
        "PeriodMonthOffset": 1
      },
      {
        "Provider": "GoogleWorkspaceIoniva",
        "FromContains": "payments-noreply@google.com",
        "SubjectContains": "ioniva.com",
        "AmountRegex": "Total in [A-Z]{3}[^0-9]{0,20}([0-9][0-9.,]+)",
        "Currency": "TRY",
        "InvoiceNoRegex": "Invoice number\\s*([0-9]+)",
        "PeriodMonthOffset": 1
      }
    ]
  },
  "VendorCosts": {
    "Anthropic": {
      "AdminApiKey": "",
      "MonthlyAmount": "",
      "Currency": "USD"
    },
    "Railway": {
      "ApiToken": "",
      "WorkspaceId": "",
      "MonthlyAmount": "",
      "Currency": "USD"
    },
    "GoogleCloud": {
      "ProjectId": "",
      "BillingTable": "",
      "ServiceAccountJson": "",
      "MonthlyAmount": "",
      "Currency": "USD"
    },
    "GoogleWorkspaceRezerval": {
      "MonthlyAmount": "",
      "Currency": "USD"
    },
    "GoogleWorkspaceIoniva": {
      "MonthlyAmount": "",
      "Currency": "USD"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/auth/logout",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}