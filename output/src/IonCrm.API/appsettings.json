{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "Jwt": {
    "Key": "",
    "Issuer": "IonCrm",
    "Audience": "IonCrm"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://ion-crm-frontend-production.up.railway.app"
    ]
  },

  "SaasA": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },

  "SaasB": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },

  "Hangfire": {
    "Enabled": false
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
