{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Secret": "",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "Issuer": "IonCrm",
    "Audience": "IonCrmUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://ion-crm-frontend-production.up.railway.app",
      "https://ion-crm-frontend-development.up.railway.app"
    ]
  },
  "SyncSettings": {
    "IntervalMinutes": 15,
    "SaasABaseUrl": "",
    "SaasBBaseUrl": "",
    "SaasAApiKey": "",
    "SaasBApiKey": ""
  },
  "SaasA": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },
  "SaasB": {
    "BaseUrl": "",
    "ApiKey": "",
    "WebhookApiKey": "",
    "ProjectId": "",
    "CallbackUrl": ""
  },
  "Hangfire": {
    "Enabled": false
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/v1/auth/logout",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}