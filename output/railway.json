{
  "$schema": "https://schema.railway.app/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/IonCrm.API/IonCrm.API.csproj -c Release -o publish"
  },
  "deploy": {
    "startCommand": "cd publish && dotnet IonCrm.API.dll",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
